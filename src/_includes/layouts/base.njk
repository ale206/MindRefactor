<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{% if title and title != site.title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description | default(site.description) }}" />

  {# ── Canonical URL ── #}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  {# ── hreflang alternate links (set in article frontmatter) ── #}
  {% if translations %}
    {% for t in translations %}
    <link rel="alternate" hreflang="{{ t.lang }}" href="{{ site.url }}{{ t.url }}" />
    {% endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}/en/" />
  {% endif %}

  {# ── RSS feed ── #}
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml" />

  {# ── Resolve OG image ── #}
  {% if slug and date %}
    {% set _ogImage = date | postImagePath(slug) %}
  {% endif %}
  {% if not _ogImage %}
    {% set _ogImage = "/assets/img/mind-refactor-home.png" %}
  {% endif %}

  {# ── Open Graph ── #}
  <meta property="og:title" content="{{ title | default(site.title) }}" />
  <meta property="og:description" content="{{ description | default(site.description) }}" />
  <meta property="og:type" content="{% if layout == 'article.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content="{{ site.url }}{{ _ogImage }}" />
  <meta property="og:image:alt" content="{{ title | default(site.title) }}" />

  {# ── Twitter Card ── #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title | default(site.title) }}" />
  <meta name="twitter:description" content="{{ description | default(site.description) }}" />
  <meta name="twitter:image" content="{{ site.url }}{{ _ogImage }}" />

  {# ── JSON-LD Structured Data ── #}
  {% if layout == "article.njk" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ description | default('') }}",
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ date | isoDate }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author.name }}",
      "url": "{{ site.author.url }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}"
    }{% if _ogImage != "/assets/img/mind-refactor-home.png" %},
    "image": "{{ site.url }}{{ _ogImage }}"{% endif %}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author.name }}",
      "url": "{{ site.author.url }}"
    }
  }
  </script>
  {% endif %}

  <link rel="stylesheet" href="{{ '/css/blog.css' | url }}" />
  <link rel="icon" href="{{ '/assets/favicon/favicon.ico' | url }}" sizes="32x32" />
  <link rel="icon" href="{{ '/assets/favicon/favicon.svg' | url }}" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="{{ '/assets/favicon/apple-touch-icon.png' | url }}" />
  <link rel="manifest" href="{{ '/assets/favicon/site.webmanifest' | url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Cookiebot -->
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="b6d47ce0-3d8c-43b3-8d7f-eb883f0ac527" type="text/javascript"></script>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-J1B0P9V70E"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-J1B0P9V70E');
  </script>
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="brand" aria-label="MindRefactor home">
        <img
          src="{{ '/assets/img/mind-refactor-logo-banner.png' | url }}"
          alt="Mind Refactor"
          class="brand-logo"
        />
      </a>
      <nav class="header-nav" aria-label="Site navigation">
      </nav>
    </div>
  </header>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-brand">
        <a href="{{ '/' | url }}">MindRefactor</a>
      </p>
      <p class="footer-copy">&copy; {{ site.currentYear }} MindRefactor. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>

